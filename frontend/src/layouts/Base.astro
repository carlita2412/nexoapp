---
import '../styles/global.css';
const { title = 'Nexo PWA' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="description" content="PWA offline-first para coordinación de ayuda médica Nexo." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import '../app.js';
    </script>
  </body>
</html>
