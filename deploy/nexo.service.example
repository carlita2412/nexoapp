[Unit]
Description=Nexo API gunicorn
After=network.target postgresql.service

[Service]
User=nexo
Group=www-data
WorkingDirectory=/opt/nexoapp
EnvironmentFile=/opt/nexoapp/.env
ExecStart=/opt/nexoapp/.venv/bin/gunicorn nexo_backend.wsgi:application \
  --bind 127.0.0.1:8000 \
  --workers 3 \
  --timeout 90 \
  --access-logfile - \
  --error-logfile -
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
