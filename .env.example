# Django
# Generar una clave real con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=nexo.ejemplo.org,localhost,127.0.0.1,testserver
CSRF_TRUSTED_ORIGINS=https://nexo.ejemplo.org
CORS_ALLOWED_ORIGINS=https://nexo.ejemplo.org
# Para desarrollo con celular o red local puedes agregar origenes exactos o regex:
# CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,http://192.168.1.20:4321
# CORS_ALLOWED_ORIGIN_REGEXES=^http://192\.168\.\d{1,3}\.\d{1,3}:4321$
SECURE_SSL_REDIRECT=true

# Frontend PWA local
# Django local por defecto: http://127.0.0.1:8000
# En desarrollo Astro usa proxy /api -> NEXO_BACKEND_URL.
NEXO_BACKEND_URL=http://127.0.0.1:8000
# Si NO usas el proxy y quieres llamar directo al backend desde el navegador:
# PUBLIC_NEXO_API_BASE=http://127.0.0.1:8000/api/v1

# Base de datos GIS
# Produccion: postgis. Pruebas locales/CI: spatialite con libsqlite3-mod-spatialite.
NEXO_DB_ENGINE=postgis
DB_NAME=nexo
DB_USER=nexo
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
# SPATIALITE_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/mod_spatialite.so

# Windows + GeoDjango/GDAL:
# Si usas QGIS u OSGeo4W, el proyecto intenta detectar automaticamente la carpeta bin.
# Si falla, descomenta y ajusta estas rutas para que todas apunten a la misma instalacion.
# Evita mezclar DLL de QGIS con DLL de OSGeo4W o PostgreSQL/PostGIS.
# QGIS_BIN_PATH=C:\Program Files\QGIS 3.40.0\bin
# GDAL_LIBRARY_PATH=C:\Program Files\QGIS 3.40.0\bin\gdal310.dll
# GEOS_LIBRARY_PATH=C:\Program Files\QGIS 3.40.0\bin\geos_c.dll
# Alternativa OSGeo4W:
# QGIS_BIN_PATH=C:\OSGeo4W\bin
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal310.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll

# Archivos persistentes
STATIC_ROOT=/var/www/nexo/staticfiles
MEDIA_ROOT=/var/www/nexo/media

# KoBoToolbox
KOBO_API_URL=https://kf.kobotoolbox.org/api/v2
KOBO_TOKEN=
KOBO_ASSET_NECESIDADES=
KOBO_ASSET_DONACIONES=
KOBO_WEBHOOK_TOKEN=
KOBO_PULL_LIMIT=500
